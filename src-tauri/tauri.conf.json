{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "MEMENTO",
  "version": "2.0.0",
  "identifier": "com.epodonios.memento",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MEMENTO — from EPODONIOS to A Who",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 480,
        "minHeight": 600,
        "center": true,
        "decorations": false,
        "transparent": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/": ""
    },
    "windows": {
      "wix": null,
      "nsis": null
    }
  }
}
